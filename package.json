{
  "name": "fetch-native-bridge",
  "version": "0.1.1",
  "description": "Fetch wrapper that bridges React Native WebView and the native app — routes fetch calls natively for file downloads and beyond",
  "license": "MIT",
  "author": "massimomoffa02@gmail.com",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.mjs",
      "require": "./dist/web/index.cjs"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.mjs",
      "require": "./dist/native/index.cjs"
    }
  },
  "main": "./dist/web/index.cjs",
  "module": "./dist/web/index.mjs",
  "types": "./dist/web/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^3.2.2",
    "jsdom": "^26.1.0",
    "rollup": "^4.41.0",
    "rollup-plugin-dts": "^6.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  },
  "peerDependencies": {
    "react-native": ">=0.70.0",
    "react-native-webview": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  },
  "keywords": [
    "react-native",
    "webview",
    "fetch",
    "bridge",
    "file-download",
    "native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MaxMoffa/fetch-native-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/MaxMoffa/fetch-native-bridge/issues"
  },
  "homepage": "https://github.com/MaxMoffa/fetch-native-bridge#readme"
}
